ENABLE_PRIORITY_NOTIFICATIONS=true
VIP_REPEAT_MINUTES=5
URGENT_REPEAT_MINUTES=10
ENABLE_BATCH_ROUTING=true
AUTO_REORDER_ON_NEW_ORDER=true
ENABLE_LIVE_TRACKING=true
LOCATION_STALE_MINUTES=10
